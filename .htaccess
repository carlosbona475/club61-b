Options -Indexes
DirectoryIndex index.php index.html

<IfModule mod_authz_core.c>
    <FilesMatch "\.(env|json|lock|sql|log|md|gitignore)$">
        Require all denied
    </FilesMatch>
    <FilesMatch "^\.">
        Require all denied
    </FilesMatch>
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # HTTPS em produção (não forçar em localhost / 127.0.0.1)
    RewriteCond %{HTTPS} off
    RewriteCond %{HTTP_HOST} !^localhost(:[0-9]+)?$ [NC]
    RewriteCond %{HTTP_HOST} !^127\.0\.0\.1(:[0-9]+)?$ [NC]
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
    RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

    # Painel admin (atalho)
    RewriteRule ^admin/?$ /features/admin/index.php [L,QSA]

    # API JSON do chat (atalhos /chat/…)
    RewriteRule ^chat/messages/?$ /features/chat/chat_actions.php [L,QSA]
    RewriteRule ^chat/send/?$ /features/chat/chat_actions.php [L,QSA]
    RewriteRule ^chat/react/?$ /features/chat/chat_actions.php [L,QSA]
    RewriteRule ^chat/online/?$ /features/chat/chat_actions.php [L,QSA]
    RewriteRule ^chat/presence/?$ /features/chat/chat_actions.php [L,QSA]

    RewriteRule ^post/delete/?$ /features/feed/delete_post.php [L,QSA]

</IfModule>
