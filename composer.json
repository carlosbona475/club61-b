{
    "name": "club61/app",
    "description": "Club61 — PHP app (MVC + services + repositories)",
    "type": "project",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Club61\\": "app/",
            "Club61\\Controllers\\": "app/controllers/",
            "Club61\\Services\\": "app/services/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Club61\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit -c phpunit.xml.dist"
    }
}
